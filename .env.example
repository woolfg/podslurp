# PodcastIndex API credentials (required)
PODCASTINDEX_API_KEY=
PODCASTINDEX_API_SECRET=

# faster-whisper settings
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Output directories (relative to where you run podslurp)
PODSLURP_OUTPUT_DIR=./transcriptions
PODSLURP_DOWNLOAD_DIR=./downloads
